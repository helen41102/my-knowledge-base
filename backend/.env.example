# =============================
# MindVault 环境变量配置
# 复制为 .env 并填写你的值
# =============================

# DeepSeek API
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Security (必须修改为随机字符串！)
SECRET_KEY=please-change-this-to-a-very-long-random-string-in-production

# App
DEBUG=false
UPLOAD_DIR=./uploads

# Database (默认 SQLite，生产环境推荐改为 PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:///./mindvault.db
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/mindvault
